# Monad testnet — get MON from https://faucet.monad.xyz (see https://docs.monad.xyz/developer-essentials/testnets)
MONAD_TESTNET_PRIVATE_KEY=0x_your_deployer_private_key

# Optional: override default public RPC (default is https://testnet-rpc.monad.xyz)
# MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz

# Required for `npx hardhat verify` on MonadScan (Etherscan v2 API). Get a key at https://etherscan.io/apis
# Guide: https://docs.monad.xyz/guides/verify-smart-contract/hardhat
ETHERSCAN_API_KEY=your_etherscan_api_key
