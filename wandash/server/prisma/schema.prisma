generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────

enum GameStatus {
  upcoming
  active
  cooldown
  completed
  cancelled
}

enum PlayerStatus {
  online
  offline
}

enum MiniGameType {
  quiz
  tap_when_green
  tap_tap_tap
  dice_roll
}

// ─── Game ───────────────────────────────────────────────────

model Game {
  id               String       @id @default(cuid())
  giveawayId       String       @unique @map("giveaway_id")      // on-chain bytes32 hex (idParam)
  hostAddress      String       @map("host_address")
  title            String       @default("")
  description      String       @default("")
  token            String       @default("0x0000000000000000000000000000000000000000")
  totalRewards     String       @map("total_rewards")             // prize pool (big number string)
  rewardsDisbursed String       @default("0") @map("rewards_disbursed")
  numWinners       Int          @map("num_winners")
  status           GameStatus   @default(upcoming)
  startTime        DateTime     @map("start_time")
  endTime          DateTime?    @map("end_time")

  currentRound      Int         @default(0) @map("current_round")
  totalRoundsPlayed Int         @default(0) @map("total_rounds_played")

  // Game config: what mini-games are allowed & scheduling
  allowedGames     MiniGameType[]  @map("allowed_games")
  currentGame      MiniGameType?   @map("current_game")
  nextGame         MiniGameType?   @map("next_game")

  cooldownEndsAt   DateTime?   @map("cooldown_ends_at")

  winners          String[]     @default([])                      // wallet addresses of winners
  resultHash       String?      @map("result_hash")
  metadata         Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  players      PlayerGame[]
  roundResults RoundResult[]

  @@index([status])
  @@index([startTime])
  @@index([hostAddress])
  @@map("games")
}

// ─── Player ─────────────────────────────────────────────────
// A player is a unique wallet. They can be in multiple games.

model Player {
  id            String   @id @default(cuid())
  walletAddress String   @unique @map("wallet_address")
  displayName   String?  @map("display_name")
  createdAt     DateTime @default(now()) @map("created_at")

  games PlayerGame[]

  @@map("players")
}

// ─── PlayerGame (join table + per-game state) ───────────────

model PlayerGame {
  id            String       @id @default(cuid())
  playerId      String       @map("player_id")
  gameId        String       @map("game_id")

  status        PlayerStatus @default(offline)
  eliminated    Boolean      @default(false)
  placement     Int?
  prize         String?                                           // amount won, if any
  joinedAt      DateTime     @default(now()) @map("joined_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([playerId, gameId])
  @@index([gameId])
  @@index([playerId])
  @@map("player_games")
}

// ─── RoundResult (per-round outcome) ────────────────────────

model RoundResult {
  id              String       @id @default(cuid())
  gameId          String       @map("game_id")
  roundNumber     Int          @map("round_number")
  gameType        MiniGameType @map("game_type")
  winnerAddresses String[]     @default([]) @map("winner_addresses")
  prizePerWinner  String?      @map("prize_per_winner")           // big number string
  completedAt     DateTime     @default(now()) @map("completed_at")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@map("round_results")
}

