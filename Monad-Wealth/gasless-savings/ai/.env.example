# Monad testnet RPC
MONAD_RPC=https://testnet-rpc.monad.xyz

# AI oracle server wallet — this key calls AIOracle.applyDecision()
# Generate a fresh key: cast wallet new
# Fund it with a small amount of MON for gas (~0.01 MON)
SERVER_KEY=0x<your_ai_oracle_private_key>

# Public address of SERVER_KEY — passed to DeployAIOracle.s.sol
AI_ORACLE_KEY_ADDRESS=0x<your_ai_oracle_public_address>

# Deployed AIOracle.sol address (set after running DeployAIOracle script)
AI_ORACLE_ADDR=0x<deployed_ai_oracle_address>

# Optional: approved yield strategy addresses
# STRATEGY_STABLE=0x05d75D2CC6C7750D14a9bfa1eEb7ECaa3F90e889  # MockStrategy
# STRATEGY_MEDIUM=
# STRATEGY_HIGH=

# HTTP port for orchestrator API
PORT=3001
